-- 5. LOW HP AUTO SAFE SPOT CONTROLLER
task.spawn(function()
    while true do
        task.wait(0.1)
        if safeSpotEnabled then
            local character = player.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if humanoid and humanoid.Health > 0 then
                local hpPercent = (humanoid.Health / humanoid.MaxHealth) * 100
                
                if hpPercent <= safeHpPercent and not safeSpotActive then
                    safeSpotActive = true -- Safely initiates upward glide and halts all combat loops
                elseif hpPercent >= 90 and safeSpotActive then
                    safeSpotActive = false -- Returns player back to combat distance and unpauses actions
                end
            end
        else
            safeSpotActive = false
        end
    end
end)


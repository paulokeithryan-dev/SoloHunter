-- State Machine Authority (Issue 5 & 3)
task.spawn(function()
    while task.wait(0.1) do
        if EngineState == "Casting" then continue end -- System locked by skills
        
        if not cachedHumanoid or cachedHumanoid.Health <= 0 then
            EngineState = "Idle"
            continue
        end

        local hpPercent = (cachedHumanoid.Health / cachedHumanoid.MaxHealth) * 100
        if safeSpotEnabled and hpPercent <= safeHpPercent then
            if EngineState ~= "SafeSpot" then
                EngineState = "SafeSpot"
                updateNoclipState()
            end
            continue
        elseif EngineState == "SafeSpot" and hpPercent >= 90 then
            EngineState = "Idle"
            updateNoclipState()
        elseif EngineState == "SafeSpot" then
            continue
        end

        if (autoAttackEnabled or autoSkillsEnabled) and targetEnemy then
            EngineState = "Combat"
        else
            EngineState = "Idle"
        end
    end
end)

-- Target Selection (Issue 8)
task.spawn(function()
    while task.wait(0.1) do
        if EngineState ~= "Combat" and EngineState ~= "Casting" then continue end
        
        if targetEnemy and isEnemyValid(targetEnemy) and cachedRoot then
            local enemyRoot = targetEnemy:FindFirstChild("HumanoidRootPart")
            if enemyRoot and (cachedRoot.Position - enemyRoot.Position).Magnitude <= autoAttackRange then
                continue -- Sticky targeting maintained
            end
        end
        
        local closest, shortestDist = nil, autoAttackRange 
        for i = 1, #enemyCache do
            local obj = enemyCache[i]
            local eRoot = obj:FindFirstChild("HumanoidRootPart")
            if eRoot and cachedRoot then
                local dist = (cachedRoot.Position - eRoot.Position).Magnitude
                if dist <= shortestDist then
                    shortestDist = dist
                    closest = obj
                end
            end
        end
        targetEnemy = closest
    end
end)

-- // HEARTBEAT ENGINE // --
local function getDesiredPosition(enemyRoot, deltaTime)
    if EngineState == "SafeSpot" then
        return enemyRoot.Position + Vector3.new(0, SAFE_HOVER_HEIGHT, 0)
    end
    
    if positioningMode == "Above" then
        return enemyRoot.Position + Vector3.new(0, HOVER_HEIGHT, 0)
    elseif positioningMode == "Circle" then
        circleAngle = circleAngle + (deltaTime * 2.5) 
        local offsetX = math.cos(circleAngle) * attackDistance
        local offsetZ = math.sin(circleAngle) * attackDistance
        return enemyRoot.Position + Vector3.new(offsetX, HOVER_HEIGHT, offsetZ)
    end
    return enemyRoot.Position
end

RunService.Heartbeat:Connect(function(deltaTime)
    if EngineState == "Idle" or not cachedRoot then return end

    local currentPos = cachedRoot.Position
    local currentLook = cachedRoot.CFrame.LookVector
    local targetPos = currentPos
    local enemyRoot = targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart")

    if EngineState == "SafeSpot" then
        targetPos = enemyRoot and (enemyRoot.Position + Vector3.new(0, SAFE_HOVER_HEIGHT, 0)) or (currentPos + Vector3.new(0, SAFE_HOVER_HEIGHT, 0))
    elseif EngineState == "Casting" then
        targetPos = currentPos -- Suspend positional updates to prevent conflicts
    elseif EngineState == "Combat" and enemyRoot then
        targetPos = getDesiredPosition(enemyRoot, deltaTime)
    end

    local travelDist = (targetPos - currentPos).Magnitude
    local requiresMove = travelDist > 0.2 -- Tolerance check (Issue 1)

    -- Flat aim logic (Issue 2)
    local flatLookPos = enemyRoot and Vector3.new(enemyRoot.Position.X, currentPos.Y, enemyRoot.Position.Z) or (currentPos + currentLook)
    local desiredLookDir = (flatLookPos - currentPos).Unit
    if desiredLookDir.Magnitude == 0 or desiredLookDir ~= desiredLookDir then desiredLookDir = currentLook end
    local requiresRotation = currentLook:Dot(desiredLookDir) < 0.999 -- Requires rotation if delta > ~2.5 degrees

    if requiresMove or exactPartAlignment then
        local newPos = currentPos
        if movementMethod == "Teleport" and EngineState ~= "SafeSpot" then
            newPos = targetPos
        else
            local speed = (EngineState == "SafeSpot") and 200 or tweenSpeed
            local step = math.min(travelDist, speed * deltaTime)
            newPos = currentPos + ((targetPos - currentPos).Unit * step)
        end

        local lookTarget = requiresRotation and Vector3.new(flatLookPos.X, newPos.Y, flatLookPos.Z) or (newPos + currentLook)
        cachedRoot.CFrame = CFrame.lookAt(newPos, lookTarget)
    elseif requiresRotation then
        cachedRoot.CFrame = CFrame.lookAt(currentPos, flatLookPos)
    end
    
    -- Velocity Optimization (Issue 6)
    if cachedRoot.AssemblyLinearVelocity.Magnitude > 0.5 then
        cachedRoot.AssemblyLinearVelocity = Vector3.zero
    end
end)


-- // BYPASS MAGNITUDE AND TRIGGER GATEWAY // --
local function teleportAndEnterPortal(portalObject, categoryName)
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local targetPart = portalObject:IsA("Model") and (portalObject.PrimaryPart or portalObject:FindFirstChildOfClass("BasePart")) or portalObject
    if not targetPart then return end
    
    -- Snap player straight into the gateway box boundary
    root.CFrame = targetPart.CFrame * CFrame.new(0, 2, 0)
    task.wait(0.25)
    
    -- Call Server Remote Transactions
    pcall(function()
        getActDungeonPlayers:InvokeServer(portalObject.Name, 1)
    end)
    task.wait(0.1)
    pcall(function()
        startDungeonFromGate:InvokeServer()
    end)
end

-- // RUNTIME PORTAL PARSER ENGINE // --
local function refreshPortalList()
    for _, child in ipairs(portalScroll:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local paths = {
        ["Normal"] = workspace:FindFirstChild("PortalSpawns") and workspace.PortalSpawns:FindFirstChild("Normal"),
        ["Infinite"] = workspace:FindFirstChild("PortalSpawns") and workspace.PortalSpawns:FindFirstChild("Infinite"),
        ["Artifact"] = workspace:FindFirstChild("PortalSpawns") and workspace.PortalSpawns:FindFirstChild("ArtifactGates"),
    }
    
    local itemsCount = 0
    
    for category, folder in pairs(paths) do
        if folder then
            for _, portal in ipairs(folder:GetChildren()) do
                itemsCount = itemsCount + 1
                
                local pBtn = Instance.new("TextButton")
                pBtn.Size = UDim2.new(1, -8, 0, 26)
                pBtn.BackgroundColor3 = category == "Normal" and Color3.fromRGB(48, 90, 48) 
                                     or category == "Infinite" and Color3.fromRGB(48, 68, 95) 
                                     or Color3.fromRGB(100, 45, 45)
                                     
                pBtn.Text = string.format("[%s] %s", category:upper(), portal.Name)
                pBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                pBtn.Font = Enum.Font.SourceSans
                pBtn.TextSize = 12
                pBtn.Parent = portalScroll
                
                local btnCorner = Instance.new("UICorner")
                btnCorner.CornerRadius = UDim.new(0, 4)
                btnCorner.Parent = pBtn
                
                pBtn.MouseButton1Click:Connect(function()
                    teleportAndEnterPortal(portal, category)
                end)
            end
        end
    end
    
    portalScroll.CanvasSize = UDim2.new(0, 0, 0, itemsCount * 30)
end


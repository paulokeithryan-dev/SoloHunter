                    if targetRoot and (playerRoot.Position - targetRoot.Position).Magnitude <= autoAttackRange then
                        -- Keep current target
                        continue
                    end
                end
                
                -- Find new closest target from cache
                local closestEnemy = nil
                local shortestDist = autoAttackRange 
                
                for i = 1, #enemyCache do
                    local obj = enemyCache[i]
                    if isEnemyValid(obj) then
                        local enemyRoot = obj:FindFirstChild("HumanoidRootPart")
                        if enemyRoot then
                            local dist = (playerRoot.Position - enemyRoot.Position).Magnitude
                            if dist <= shortestDist then
                                shortestDist = dist
                                closestEnemy = obj
                            end
                        end
                    end
                end
                targetEnemy = closestEnemy
            end
        else
            targetEnemy = nil
        end
        task.wait(0.2)
    end
end)


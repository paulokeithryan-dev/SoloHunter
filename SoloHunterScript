-- // INSTANT REMOTE DROP VACUUM // --
local function scanAndVerifyDrop(obj)
    if not systemEnabled or not autoCollectEnabled or not obj then return end
    local dropId = nil
    local uuidPattern = "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x"

    if string.match(obj.Name, uuidPattern) then
        dropId = obj.Name
    end
    if not dropId then
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("StringValue") and string.match(child.Value, uuidPattern) then
                dropId = child.Value
                break
            elseif string.match(child.Name, uuidPattern) then
                dropId = child.Name
                break
            end
        end
    end
    if not dropId then
        for attrName, attrVal in pairs(obj:GetAttributes()) do
            if type(attrVal) == "string" and string.match(attrVal, uuidPattern) then
                dropId = attrVal
                break
            end
        end
    end

    if dropId and not processedDrops[dropId] then
        processedDrops[dropId] = true
        task.spawn(function() pcall(function() dropRemote:InvokeServer(dropId) end) end)
    end
end

local cameraInstance = workspace:FindFirstChildOfClass("Camera") or workspace:FindFirstChild("Camera")
if cameraInstance then 
    cameraInstance.DescendantAdded:Connect(function(descendant)
        pcall(scanAndVerifyDrop, descendant)

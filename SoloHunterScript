-- // CORE LOGIC & OPTIMIZATION // --

local function isEnemyValid(model)
    if not model or not model.Parent or model == cachedCharacter then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    local root = model:FindFirstChild("HumanoidRootPart")
    if hum and root and hum.Health > 0 and hum.MaxHealth > 0 then
        local nameLower = model.Name:lower()
        for i = 1, #BLACKLIST_KEYWORDS do
            if string.find(nameLower, BLACKLIST_KEYWORDS[i]) then return false end
        end
        return true
    end
    return false
end


end)

-- Positioning & Alignment Loop (Heartbeat-Driven)
RunService.Heartbeat:Connect(function()
    if not systemEnabled or isSafeTeleported then return end

    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not root or (humanoid and humanoid.Health <= 0) then return end
    
    if targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") and targetEnemy:FindFirstChildOfClass("Humanoid") and targetEnemy:FindFirstChildOfClass("Humanoid").Health > 0 then
        local enemyRoot = targetEnemy.HumanoidRootPart
        local targetPosition
        
        if exactPartAlignment then
            -- Projects movement perfectly calculated down to the precise part coordinate
            local direction = (root.Position - enemyRoot.Position).Unit
            if direction.Magnitude == 0 or tostring(direction) == "NAN" then direction = Vector3.new(0,0,1) end
            targetPosition = enemyRoot.Position + (direction * attackDistance)
        else
            -- Traditional spatial calculation fallback box layout
            local _, boxSize = targetEnemy:GetBoundingBox()
            local targetY = enemyRoot.Position.Y + (boxSize.Y / 2) + HOVER_HEIGHT
            targetPosition = Vector3.new(enemyRoot.Position.X, targetY, enemyRoot.Position.Z)
        end
        
        root.CFrame = CFrame.lookAt(targetPosition, enemyRoot.Position)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    else
        targetEnemy = nil
    end
end)


-- 6. LOW HP SAFE SPOT MODULE
local isSafeTeleported = false
local returnPosition = nil

task.spawn(function()
    while true do
        task.wait(0.2)
        if safeSpotEnabled then
            local character = player.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local root = character and character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and root and humanoid.Health > 0 then
                local hpPercent = (humanoid.Health / humanoid.MaxHealth) * 100
                if hpPercent <= safeHpPercent and not isSafeTeleported then
                    returnPosition = root.CFrame
                    isSafeTeleported = true
                    root.CFrame = root.CFrame + Vector3.new(0, 500, 0)
                    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                elseif hpPercent > 75 and isSafeTeleported then
                    if returnPosition then root.CFrame = returnPosition end
                    isSafeTeleported = false
                end
            end
        end
    end
end)


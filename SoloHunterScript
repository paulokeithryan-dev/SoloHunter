-- // UNIVERSAL DROP DETECTION // --
local function getDropId(obj)
    local uuidPattern = "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x"
    
    -- Check name
    if string.match(obj.Name, uuidPattern) then return obj.Name end
    
    -- Check attributes
    for name, val in pairs(obj:GetAttributes()) do
        if type(val) == "string" and string.match(val, uuidPattern) then return val end
    end
    
    -- Check children (StringValues often hold IDs)
    for _, child in ipairs(obj:GetChildren()) do
        if child:IsA("StringValue") and string.match(child.Value, uuidPattern) then
            return child.Value
        elseif string.match(child.Name, uuidPattern) then
            return child.Name
        end
    end
    
    return nil
end

local function isUniversalDrop(obj)
    if not obj:IsA("BasePart") and not obj:IsA("Model") then return false end
    
    -- Common drop indicators
    local indicators = {"Gold", "Coin", "Item", "Loot", "Drop", "Gem", "Crystal"}
    for _, tag in ipairs(indicators) do
        if string.find(obj.Name:lower(), tag:lower()) then return true end
    end
    
    -- Check for specific components
    if obj:FindFirstChildOfClass("TouchTransmitter") or obj:FindFirstChildOfClass("ClickDetector") then
        return true
    end
    
    -- Check for the ID pattern
    if getDropId(obj) then return true end
    
    return false
end

local function collectDrop(obj)
    if not autoCollectEnabled or processedDrops[obj] then return end
    
    local dropId = getDropId(obj)
    if dropId then
        processedDrops[dropId] = true
        pcall(function() dropRemote:InvokeServer(dropId) end)
    else
        -- If no ID, try physical collection (moving to it)
        processedDrops[obj] = true
        -- Physical collection is handled by the pathfinding loop
    end
end

-- // TARGET AREA DETECTION // --
local function getTargetArea()
    -- Look for Beams (often used for quest markers)
    for _, beam in ipairs(workspace:GetDescendants()) do
        if beam:IsA("Beam") and beam.Enabled then
            local attachment = beam.Attachment1
            if attachment then return attachment.WorldPosition end
        end
    end
    
    -- Look for SelectionBoxes or Highlights
    for _, highlight in ipairs(workspace:GetDescendants()) do
        if (highlight:IsA("Highlight") or highlight:IsA("SelectionBox")) and highlight.Adornee then
            local target = highlight.Adornee
            if target:IsA("BasePart") then return target.Position
            elseif target:IsA("Model") and target.PrimaryPart then return target.PrimaryPart.Position end
        end
    end
    
    -- Look for specific names
    local targetNames = {"Target", "Goal", "Waypoint", "Objective", "Quest"}
    for _, name in ipairs(targetNames) do
        local found = workspace:FindFirstChild(name, true)
        if found then
            if found:IsA("BasePart") then return found.Position
            elseif found:IsA("Model") and found.PrimaryPart then return found.PrimaryPart.Position end
        end
    end
    
    return nil
end

-- // ENEMY DETECTION // --
local function getClosestEnemy()
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local closest = nil
    local dist = MAX_DETECTION_DIST
    
    for _, m in ipairs(workspace:GetDescendants()) do
        if m:IsA("Model") and m ~= character then
            local hum = m:FindFirstChildOfClass("Humanoid")
            local mRoot = m:FindFirstChild("HumanoidRootPart")
            if hum and mRoot and hum.Health > 0 then
                local d = (root.Position - mRoot.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = m
                end
            end
        end
    end
    return closest
end

-- // PATHFINDING ENGINE // --
local function moveTo(position)
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not root then return end
    
    local success, _ = pcall(function()
        path:ComputeAsync(root.Position, position)
    end)
    
    if success and path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()
        if #waypoints > 1 then
            local nextPoint = waypoints[2]
            if nextPoint.Action == Enum.PathWaypointAction.Jump then
                humanoid.Jump = true
            end
            humanoid:MoveTo(nextPoint.Position)
        else
            humanoid:MoveTo(position)
        end
    else
        humanoid:MoveTo(position) -- Fallback
    end
end

task.spawn(function()
    while true do
        task.wait(0.1)
        if not systemEnabled then continue end
        
        local character = player.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        
        -- Priority 1: Nearby Drops
        local closestDrop = nil
        local dropDist = 50
        for _, obj in ipairs(workspace:GetDescendants()) do
            if isUniversalDrop(obj) then
                local pos = obj:IsA("Model") and (obj.PrimaryPart and obj.PrimaryPart.Position) or obj.Position
                if pos then
                    local d = (root.Position - pos).Magnitude
                    if d < dropDist then
                        dropDist = d
                        closestDrop = obj
                    end
                end
            end
        end
        
        if closestDrop then
            local pos = closestDrop:IsA("Model") and closestDrop.PrimaryPart.Position or closestDrop.Position
            if dropDist < 5 then
                collectDrop(closestDrop)
            else
                moveTo(pos)
            end
            continue
        end
        
        -- Priority 2: Target Area (Quest/Navigation)
        if autoPathToTarget then
            local targetPos = getTargetArea()
            if targetPos then
                if (root.Position - targetPos).Magnitude > 5 then
                    moveTo(targetPos)
                    continue
                end
            end
        end
        
        -- Priority 3: Enemies
        local enemy = getClosestEnemy()
        if enemy then
            local enemyRoot = enemy.HumanoidRootPart
            local dist = (root.Position - enemyRoot.Position).Magnitude
            if dist > STOP_DISTANCE then
                moveTo(enemyRoot.Position)
            else
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                humanoid:MoveTo(root.Position)
                root.CFrame = CFrame.lookAt(root.Position, Vector3.new(enemyRoot.Position.X, root.Position.Y, enemyRoot.Position.Z))
            end
        end
    end
end)


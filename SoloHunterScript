        _G.CombatStance = Value
    end
})

-- Dynamic Real-time Child Collector Sniper
pcall(function()
    if DropsFolder then
        DropsFolder.ChildAdded:Connect(function(drop)
            if _G.AutoCollect then
                local collectRF = getCollectDropRemote()
                if collectRF then
                    pcall(function() collectRF:InvokeServer(drop) end)
                end
            end
        end)
    end
end)


-- 8. AUTO-DUNGEON PROGRESSION MODULE
task.spawn(function()
    while true do
        task.wait(1.5)
        if autoDungeonEnabled then
            local mainGui = player.PlayerGui:FindFirstChild("Main")
            local startBtn = mainGui and mainGui:FindFirstChild("StartBtn")
            
            local standardProximityPass = false
            local character = player.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            
            if root then
                local closeLandmark = false
                for _, element in ipairs(workspace:GetChildren()) do
                    if (element.Name:lower():find("gate") or element.Name:lower():find("dungeon")) and element:IsA("BasePart") then
                        if (root.Position - element.Position).Magnitude <= autoDungeonRange then
                            closeLandmark = true
                            break
                        end
                    end
                end
                standardProximityPass = closeLandmark
            end
            
            if startBtn and startBtn.Visible then
                task.spawn(pcall, function() startDungeonRemote:InvokeServer() end)
            end
            
            local gateGui = player.PlayerGui:FindFirstChild("Gate")
            if gateGui and (gateGui.Enabled or (gateGui:FindFirstChild("Main") and gateGui.Main.Visible)) then
                task.spawn(pcall, function() enterGateRemote:InvokeServer() end)
            end
        end
    end
end)


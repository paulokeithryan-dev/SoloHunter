end)

-- // AUTO SKILL CAST LOOP // --
local skills = {Enum.KeyCode.F, Enum.KeyCode.R, Enum.KeyCode.C}

task.spawn(function()
    while true do
        for _, key in ipairs(skills) do
            if systemEnabled and targetEnemy then
                VirtualInputManager:SendKeyEvent(true, key, false, game)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, key, false, game)
                
                task.wait(SKILL_INTERVAL)
            else
                task.wait(0.5)
            end
        end
    end
end)

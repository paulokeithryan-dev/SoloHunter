-- =============================================================================
-- PHASE 3: THE TRACKING & MOTION ENGINE
-- =============================================================================
local targetEnemy = nil
task.spawn(function()
    local function getEnemyModelFromPart(part)
        local current = part
        while current and current ~= workspace do
            if current:IsA("Model") and current:FindFirstChildOfClass("Humanoid") then return current end
            current = current.Parent
        end
        return nil
    end

    while true do
        if systemEnabled then
            local character = player.Character
            local playerRoot = character and character:FindFirstChild("HumanoidRootPart")
            if playerRoot then
                local closestEnemy = nil
                local shortestDistance = MAX_DETECTION_DIST
                local overlapParams = OverlapParams.new()
                overlapParams.FilterType = Enum.RaycastFilterType.Exclude
                overlapParams.FilterDescendantsInstances = {character}
                local success, parts = pcall(function() return workspace:GetPartBoundsInRadius(playerRoot.Position, MAX_DETECTION_DIST, overlapParams) end)
                if success and parts then
                    local checkedModels = {}
                    for _, part in ipairs(parts) do
                        local model = getEnemyModelFromPart(part)
                        if model and not checkedModels[model] and model ~= character then
                            checkedModels[model] = true
                            local hum = model:FindFirstChildOfClass("Humanoid")
                            local eRoot = model:FindFirstChild("HumanoidRootPart")
                            if hum and eRoot and hum.Health > 0 then
                                local distance = (playerRoot.Position - eRoot.Position).Magnitude
                                if distance < shortestDistance then shortestDistance = distance; closestEnemy = model end
                            end
                        end
                    end
                end
                targetEnemy = closestEnemy
            else
                targetEnemy = nil
            end
        else
            targetEnemy = nil
        end
        task.wait(0.05) -- Faster scanning
    end
end)

-- FLAWLESS MOTION ENGINE
task.spawn(function()
    local lastPos = Vector3.new(0,0,0)
    local stuckTime = 0
    
    while true do
        task.wait(0.03) -- Faster tick for responsiveness
        if systemEnabled and targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") then
            local char = player.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local root = char and char:FindFirstChild("HumanoidRootPart")
            
            if hum and root and hum.Health > 0 then
                hum.WalkSpeed = WALK_SPEED
                local enemyRoot = targetEnemy.HumanoidRootPart
                local dist = (root.Position - enemyRoot.Position).Magnitude
                
                -- Stuck Detection
                if (root.Position - lastPos).Magnitude < 0.2 then
                    stuckTime = stuckTime + 0.03
                else
                    stuckTime = 0
                end
                lastPos = root.Position

                if dist > STOP_DISTANCE then
                    -- If stuck or path invalidated, force repath
                    if stuckTime > 0.5 then
                        path:ComputeAsync(root.Position, enemyRoot.Position)
                        stuckTime = 0
                    end
                    
                    local success, err = pcall(function() path:ComputeAsync(root.Position, enemyRoot.Position) end)
                    if success and path.Status == Enum.PathStatus.Success then
                        local waypoints = path:GetWaypoints()
                        if waypoints[2] then
                            hum:MoveTo(waypoints[2].Position)
                            if waypoints[2].Action == Enum.PathWaypointAction.Jump then hum.Jump = true end
                        end
                    else
                        hum:MoveTo(enemyRoot.Position)
                    end
                else
                    hum:MoveTo(root.Position) -- Stop
                    root.CFrame = CFrame.lookAt(root.Position, Vector3.new(enemyRoot.Position.X, root.Position.Y, enemyRoot.Position.Z))
                    stuckTime = 0
                end
            end
        end
    end
end)


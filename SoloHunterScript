        local isGlobal = type(dropData) == "table" and dropData.GlobalDrop == true or false
        task.spawn(function() pcall(function() collectDropRemote:InvokeServer(dropId, isGlobal) end) end)
    end
end)

spawnChestRemote.OnClientEvent:Connect(function(...)
    if autoOpenChests then
        local args = {...}
        local chestUUID = nil
        for _, arg in ipairs(args) do
            if type(arg) == "string" and arg:match("^%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x$") then
                chestUUID = arg break
            elseif type(arg) == "table" and arg.ChestUUID then
                chestUUID = arg.ChestUUID break
            end
        end
        if not chestUUID then
            if typeof(args[2]) == "CFrame" and type(args[3]) == "string" then chestUUID = args[3]
            elseif typeof(args[1]) == "CFrame" and type(args[2]) == "string" then chestUUID = args[2] end
        end
        if chestUUID then
            task.spawn(function() pcall(function() openChestRemote:InvokeServer(chestUUID) end) end)
        end
    end
end)


    local function connectChestListener()
        if chestConnection then chestConnection:Disconnect() end
        chestConnection = spawnChestRemote.OnClientEvent:Connect(function(...)
            if autoOpenChests then
                local args = {...}
                local chestUUID = nil
                
                -- Dynamic payload mapping
                for _, arg in ipairs(args) do
                    if type(arg) == "string" and arg:match("^%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x$") then

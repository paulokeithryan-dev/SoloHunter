-- 3. AUTO SKILLS SYSTEM (Stops during Safe Spot Recovery)
local skillBinds = {
    {Key = Enum.KeyCode.F, GetEnabled = function() return castF end},
    {Key = Enum.KeyCode.R, GetEnabled = function() return castR end},
    {Key = Enum.KeyCode.C, GetEnabled = function() return castC end},
    {Key = Enum.KeyCode.G, GetEnabled = function() return castG end},
    {Key = Enum.KeyCode.V, GetEnabled = function() return castV end},
}

task.spawn(function()
    while true do
        task.wait(0.1)
        if autoSkillsEnabled and targetEnemy and not safeSpotActive then
            for _, skillData in ipairs(skillBinds) do
                -- Checks mid-iteration to handle instant safety state updates or setting changes
                if autoSkillsEnabled and targetEnemy and not safeSpotActive and skillData.GetEnabled() then
                    local character = player.Character
                    local root = character and character:FindFirstChild("HumanoidRootPart")
                    local enemyRoot = targetEnemy:FindFirstChild("HumanoidRootPart")
                    
                    if root and enemyRoot and character:FindFirstChildOfClass("Tool") then
                        local currentDistance = (root.Position - enemyRoot.Position).Magnitude
                        if currentDistance <= (attackDistance + 8) then
                            VirtualInputManager:SendKeyEvent(true, skillData.Key, false, game)
                            task.wait(0.05)
                            VirtualInputManager:SendKeyEvent(false, skillData.Key, false, game)
                            task.wait(SKILL_INTERVAL)
                        end
                    end
                end
            end
        end
    end
end)


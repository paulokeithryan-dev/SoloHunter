-- // DIAGNOSTIC SCRIPT: Remote Path Finder // --
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local rs = ReplicatedStorage:FindFirstChild("RemoteServices")

if not rs then
    warn("CRITICAL ERROR: 'RemoteServices' folder not found in ReplicatedStorage. Is the game loaded?")
    return
end

print("--- RemoteServices Found. Mapping children... ---")

for _, child in pairs(rs:GetChildren()) do
    print("Found Service: " .. child.Name)
    if child:FindFirstChild("RF") then
        for _, remote in pairs(child.RF:GetChildren()) do
            print("   -> Remote Found: " .. remote.Name .. " | Path: " .. remote:GetFullName())
        end
    end
end

print("--- Mapping Complete. Compare these names with the script's paths. ---")

local function secureFetchPath(pathArray)
    local currentObj = game
    for _, segmentName in ipairs(pathArray) do
        if not currentObj then return nil end
        local success, foundChild = pcall(function() return currentObj:WaitForChild(segmentName, 1.5) end)
        if success and foundChild then currentObj = foundChild else return nil end
    end
    return currentObj
end


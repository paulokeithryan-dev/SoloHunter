local enterGateRemote = ReplicatedStorage:WaitForChild("RemoteServices"):WaitForChild("PortalService"):WaitForChild("RF"):WaitForChild("CanEnterGate")

-- // CONFIG STATE STRUCURE // --
_G.SystemEnabled = false
_G.AutoEquipEnabled = true 
_G.AutoCollectEnabled = true  
_G.AutoPotionEnabled = true   
_G.AutoDungeonEnabled = true  

local HOVER_HEIGHT = 4        
local MAX_DETECTION_DIST = 300  
local M1_SPEED = 0.1            
local SKILL_INTERVAL = 1.5      
local targetEnemy = nil

-- // TRADITIONAL TARGETING FUNCTIONS // --
local function isEnemy(model)
    if model:IsA("Model") and model ~= player.Character then
        local humanoid = model:FindFirstChildOfClass("Humanoid")
        local root = model:FindFirstChild("HumanoidRootPart")
        if humanoid and root and humanoid.Health > 0 then
            return true
        end
    end
    return false
end

local function getClosestEnemy()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local playerRoot = character.HumanoidRootPart
    local closestEnemy = nil
    local shortestDistance = MAX_DETECTION_DIST

    for _, obj in pairs(workspace:GetDescendants()) do
        if isEnemy(obj) then
            local enemyRoot = obj.HumanoidRootPart
            local distance = (playerRoot.Position - enemyRoot.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestEnemy = obj
            end
        end
    end
    return closestEnemy
end

-- // HEARTBEAT POSITIONING & AIMING LOOP // --
RunService.Heartbeat:Connect(function()
    if not _G.SystemEnabled then 
        targetEnemy = nil
        return 
    end

    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if not root or (humanoid and humanoid.Health <= 0) then return end
    
    targetEnemy = getClosestEnemy()
    
    if targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") then
        local enemyRoot = targetEnemy.HumanoidRootPart
        local _, boxSize = targetEnemy:GetBoundingBox()
        
        local targetY = enemyRoot.Position.Y + (boxSize.Y / 2) + HOVER_HEIGHT
        local targetPosition = Vector3.new(enemyRoot.Position.X, targetY, enemyRoot.Position.Z)
        
        root.CFrame = CFrame.lookAt(targetPosition, enemyRoot.Position)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
end)

-- // REAL-TIME DROP SCANNER FUNCTIONS // --
local function processDrop(obj)
    if not _G.SystemEnabled or not _G.AutoCollectEnabled or not obj then return end
    
    local nameLower = obj.Name:lower()
    local parentNameLower = (obj.Parent and obj.Parent.Name:lower()) or ""
    
    local isDrop = nameLower:find("drop") 
        or nameLower:find("loot") 
        or nameLower:find("item")
        or parentNameLower:find("drop") 
        or parentNameLower:find("loot")
        or obj:IsA("ProximityPrompt")
        or obj:IsA("TouchTransmitter")
        
    if isDrop then
        task.spawn(function()
            pcall(function() dropRemote:InvokeServer(obj) end)
            if obj.Parent and obj.Parent:IsA("Model") then
                pcall(function() dropRemote:InvokeServer(obj.Parent) end)
            end
        end)
    end
end

workspace.DescendantAdded:Connect(processDrop)

-- // BACKGROUND THREADS // --

-- Traditional Auto-Potion Loop
task.spawn(function()
    while true do
        task.wait(0.3)
        if _G.SystemEnabled and _G.AutoPotionEnabled then
            local character = player.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if humanoid and humanoid.Health > 0 then
                local hpPercent = humanoid.Health / humanoid.MaxHealth
                if hpPercent <= 0.5 then
                    pcall(function() healRemote:InvokeServer() end)
                    task.wait(1.5) 
                end
            end
        end
    end
end)

-- Workspace Scan Collection Loop
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.SystemEnabled and _G.AutoCollectEnabled then
            for _, obj in ipairs(workspace:GetDescendants()) do
                processDrop(obj)
            end
        end
    end
end)

-- Auto Weapon Equip Loop
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.SystemEnabled and _G.AutoEquipEnabled then
            local character = player.Character
            if character and character:FindFirstChildOfClass("Humanoid") and character.Humanoid.Health > 0 then
                local holdingTool = character:FindFirstChildOfClass("Tool")
                if not holdingTool then
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                    task.wait(0.02)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                end
            end
        end
    end
end)

-- Double-Engine Hybrid Attack Loop
task.spawn(function()
    while true do
        task.wait(M1_SPEED)
        if _G.SystemEnabled and targetEnemy then
            task.spawn(function()
                pcall(function() 
                    useWeaponRemote:InvokeServer(1, { targetEnemy }, 0.4, "", "CS_HW_V1")[cite: 3]
                end)
            end)
            
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            task.wait(0.01)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
    end
end)

-- Auto-Dungeon Loop
task.spawn(function()
    while true do
        task.wait(1.5)
        if _G.SystemEnabled and _G.AutoDungeonEnabled then
            task.spawn(pcall, function() startDungeonRemote:InvokeServer() end)
            task.spawn(pcall, function() enterGateRemote:InvokeServer() end)
        end
    end
end)

-- Auto Skill Cast Loop
local skills = {Enum.KeyCode.F, Enum.KeyCode.R, Enum.KeyCode.C}
task.spawn(function()
    while true do
        for _, key in ipairs(skills) do
            if _G.SystemEnabled and targetEnemy then
                VirtualInputManager:SendKeyEvent(true, key, false, game)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, key, false, game)
                task.wait(SKILL_INTERVAL)
            else
                task.wait(0.5)
            end
        end
    end
end)


local cachedCharacter, cachedRoot, cachedHumanoid
local function updateCharacterCache(char)
    if char then
        cachedCharacter = char
        cachedRoot = char:WaitForChild("HumanoidRootPart", 5)
        cachedHumanoid = char:WaitForChild("Humanoid", 5)
    else
        cachedCharacter, cachedRoot, cachedHumanoid = nil, nil, nil

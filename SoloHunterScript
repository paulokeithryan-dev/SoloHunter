                if chestUUID then
                    task.spawn(pcall, function()
                        openChestRemote:InvokeServer(chestUUID)
                    end)
                end
            end
        end)
    end
    
    connectChestListener()
    
    player.CharacterAdded:Connect(function()
        task.wait(1)
        connectChestListener()
    end)
end)


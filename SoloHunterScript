-- Loop 1: High-Frequency Teleportation & Position Maintenance (Stance Aware)
RunService.Heartbeat:Connect(function()
    if not _G.AutoFarm or not Player.Character then 
        TargetLabel:Set("Current Target: None")
        HealthLabel:Set("Target Health: N/A")
        return 
    end
    
    local myRoot = Player.Character:FindFirstChild("HumanoidRootPart")
    local enemy = getClosestEnemy()
    
    if myRoot and enemy then
        local enemyRoot = enemy:FindFirstChild("HumanoidRootPart")
        local enemyHumanoid = enemy:FindFirstChildOfClass("Humanoid")
        
        if enemyRoot and enemyHumanoid then
            -- Live Dashboard updates
            TargetLabel:Set("Current Target: " .. enemy.Name)
            HealthLabel:Set("Target Health: " .. math.round(enemyHumanoid.Health) .. " / " .. math.round(enemyHumanoid.MaxHealth))
            
            local boxSize = enemy:GetExtentsSize()
            local targetPosition
            
            -- Dynamic Stance Handling
            if TELEPORT_STANCE == "Above" then
                local targetY = enemyRoot.Position.Y + (boxSize.Y / 2) + HOVER_HEIGHT
                targetPosition = Vector3.new(enemyRoot.Position.X, targetY, enemyRoot.Position.Z)
            elseif TELEPORT_STANCE == "Behind" then
                -- Positions character 4 studs directly behind the enemy face direction
                targetPosition = enemyRoot.CFrame.Position - (enemyRoot.CFrame.LookVector * 4)
            elseif TELEPORT_STANCE == "Below" then
                -- Clips character right below the enemy hitbox floor
                local targetY = enemyRoot.Position.Y - (boxSize.Y / 2) - HOVER_HEIGHT
                targetPosition = Vector3.new(enemyRoot.Position.X, targetY, enemyRoot.Position.Z)
            end
            
            -- Execute Teleport
            myRoot.CFrame = CFrame.new(targetPosition, enemyRoot.Position)
        end
    else
        TargetLabel:Set("Current Target: None")
        HealthLabel:Set("Target Health: N/A")
    end
end)

-- Loop 2: Async Basic Attacks (M1)
task.spawn(function()
    while true do

            end
        end
        task.wait(SKILL_INTERVAL) -- Dynamic yielding tied directly to your interval slider
    end
end)

-- Loop 4: Event-Driven Drop Processing (Instant Pickup + Counter Hook)
local function processDrop(drop)
    if not drop:IsA("BasePart") then return end
    task.spawn(function()
        while drop.Parent and _G.AutoCollect do
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                local myRoot = Player.Character.HumanoidRootPart
                -- Instantly fire touch interest if engine uses standard parts, or move to character
                firetouchinterest(myRoot, drop, 0)
                firetouchinterest(myRoot, drop, 1)
                
                -- Alternate physics backup: Pull drop directly to character frame
                drop.CFrame = myRoot.CFrame
            end
            task.wait(0.1)
        end
        
        -- If the drop is gone (collected successfully), update Dashboard tally
        if not drop.Parent then
            DROPS_COLLECTED = DROPS_COLLECTED + 1
            DropsLabel:Set("Drops Collected: " .. tostring(DROPS_COLLECTED))
        end
    end)
end

-- Loop 5: Async Dungeon Auto-Retry & Portal Spawner
task.spawn(function()
    while true do
        if _G.AutoDungeon then
            pcall(function()
                -- Primary: Invoke the RemoteFunction intercepted by Cobalt
                if DungeonPortalRF then
                    DungeonPortalRF:InvokeServer("retry")
                end
                
                -- Secondary Backup: Fallback to the ReplicaService layer if direct infrastructure changes
                if ReplicaSignal then
                    ReplicaSignal:FireServer("retry")
                end
            end)
        end
        task.wait(DUNGEON_RETRY_DELAY)
    end
end)


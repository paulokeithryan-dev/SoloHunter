-- 1. Initialize Fluent UI Library with Fallbacks
local Fluent = nil
local success, result = pcall(function()
    return loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
end)

if success and result then
    Fluent = result
else
    -- Alternate mirror if GitHub releases are being throttled or blocked
    local fallbackSuccess, fallbackResult = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/main.lua"))()
    end)
    if fallbackSuccess then Fluent = fallbackResult end
end

if not Fluent then
    error("[Automation Hub] Network Error: Executor blocked the Fluent UI download. Please try the UI-less version.")
    return
end

-- 2. Create Window
local Window = Fluent:CreateWindow({
    Title = "Universal Automation Hub",
    SubTitle = "by Assistant",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = false, -- Disabled to avoid rendering lag or crashes on budget executors
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

-- 3. Setup Tabs
local Tabs = {
    Main = Window:AddTab({ Title = "Automation", Icon = "play" }),
    Settings = Window:AddTab({ Title = "Configurations", Icon = "settings" })
}

-- Safe environment variables
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Network Services & Remotes Structure
local RemoteServices = ReplicatedStorage:WaitForChild("RemoteServices", 5)

local CollectDropRF = RemoteServices 
    and RemoteServices:WaitForChild("DropsService", 5) 
    and RemoteServices.DropsService:WaitForChild("RF", 5) 
    and RemoteServices.DropsService.RF:WaitForChild("CollectDrop", 5)

local UseWeaponRF = RemoteServices 
    and RemoteServices:WaitForChild("CombatService", 5)
    and RemoteServices.CombatService:WaitForChild("RF", 5)
    and RemoteServices.CombatService.RF:WaitForChild("UseWeapon", 5)

-- Strict Folder Mapping (Prevents workspace flooding)
local Camera = workspace:FindFirstChild("Camera")
local DropsFolder = (Camera and Camera:FindFirstChild("Drops")) or workspace:FindFirstChild("Drops")
local EnemiesFolder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Monsters")

-- Script Global Variables
local Options = Fluent.Options
_G.AutoFarm = false
_G.AutoCollect = false
_G.FarmDistance = 5
_G.CombatStance = "Above"

-- 4. Helper Functions
local function getClosestEnemy()
    if not EnemiesFolder then return nil end
    local closest = nil
    local shortestDistance = math.huge
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local myHrp = character.HumanoidRootPart

    pcall(function()
        for _, enemy in ipairs(EnemiesFolder:GetChildren()) do
            if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") then
                if enemy.Humanoid.Health > 0 then
                    local distance = (enemy.HumanoidRootPart.Position - myHrp.Position).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closest = enemy
                    end
                end
            end
        end
    end)
    return closest
end

local function teleportToPosition(pos)
    pcall(function()
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = pos
        end
    end)
end

local function processDrop(drop)
    if not _G.AutoCollect or not CollectDropRF then return end
    task.spawn(function()
        pcall(function()
            CollectDropRF:InvokeServer(drop)
        end)
    end)
end

-- Anti-AFK
pcall(function()
    LocalPlayer.Idled:Connect(function()
        VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        task.wait(1)
        VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    end)
end)

-- 5. Build Tab Elements

-- Automation Tab
Tabs.Main:AddSection("Combat Loops")

local ToggleFarm = Tabs.Main:AddToggle("Toggle_AutoFarm", {Title = "Auto Farm Enemies", Default = false })
ToggleFarm:OnChanged(function()
    _G.AutoFarm = Options.Toggle_AutoFarm.Value
    if _G.AutoFarm then
        task.spawn(function()
            while _G.AutoFarm do
                local target = getClosestEnemy()
                if target and target:FindFirstChild("HumanoidRootPart") then
                    
                    local targetCFrame = target.HumanoidRootPart.CFrame
                    local finalCFrame = targetCFrame * CFrame.new(0, _G.FarmDistance, 0)
                    
                    if _G.CombatStance == "Behind" then
                        finalCFrame = targetCFrame * CFrame.new(0, 0, _G.FarmDistance)
                    elseif _G.CombatStance == "Below" then
                        finalCFrame = targetCFrame * CFrame.new(0, -_G.FarmDistance, 0)
                    end
                    
                    teleportToPosition(finalCFrame)
                    
                    pcall(function()
                        if UseWeaponRF then
                            UseWeaponRF:InvokeServer(1, { target }, 0.4, nil, "CS_HW_V1")[cite: 3]
                        else
                            local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if tool then tool:Activate() end
                        end
                    end)
                end
                task.wait(0.1)
            end
        end)
    end
end)

local ToggleCollect = Tabs.Main:AddToggle("Toggle_AutoCollect", {Title = "Auto Collect Drops", Default = false })
ToggleCollect:OnChanged(function()
    _G.AutoCollect = Options.Toggle_AutoCollect.Value
    if _G.AutoCollect then
        task.spawn(function()
            while _G.AutoCollect do
                pcall(function()
                    if DropsFolder then
                        for _, drop in ipairs(DropsFolder:GetChildren()) do
                            if CollectDropRF then
                                task.spawn(function()
                                    CollectDropRF:InvokeServer(drop)
                                end)
                            else
                                teleportToPosition(drop.CFrame)
                                task.wait(0.1)
                            end
                        end
                    else
                        warn("[Warning] Drops folder cannot be found in workspace currently.")
                    end
                end)
                task.wait(0.4)
            end
        end)
    end
end)

-- Configurations Tab
Tabs.Settings:AddSection("Farming Adjustments")

local SliderDistance = Tabs.Settings:AddSlider("Slider_Distance", {
    Title = "Target Attack Distance",
    Description = "Distance maintained from target",
    Default = 5,
    Min = 2,
    Max = 15,
    Rounding = 0,
    Callback = function(Value)
        _G.FarmDistance = Value
    end
})

local DropdownStance = Tabs.Settings:AddDropdown("Dropdown_Stance", {
    Title = "Teleport Combat Stance",
    Values = {"Above", "Behind", "Below"},
    CurrentOption = "Above",
    Callback = function(Value)
        _G.CombatStance = Value
    end
})

-- 6. Safe Startup Initialization
pcall(function()
    if DropsFolder then
        DropsFolder.ChildAdded:Connect(processDrop)
    end
end)

-- Select the main tab on open
Tabs.Main:Select()

Fluent:Notify({
    Title = "System Loaded",
    Content = "Fluent Execution engine compiled successfully.",
    Duration = 5
})

local function secureFetchPath(pathArray)
    local currentObj = game
    for _, segmentName in ipairs(pathArray) do
        if not currentObj then return nil end
        local success, foundChild = pcall(function()
            return currentObj:WaitForChild(segmentName, 1.5)
        end)
        if success and foundChild then
            currentObj = foundChild
        else
            return nil
        end
    end
    return currentObj
end

-- Resolve Remotes safely without any risk of indexing nil
local dropRemote = secureFetchPath({"ReplicatedStorage", "RemoteServices", "DropsService", "RF", "CollectDrop"})
local healRemote = secureFetchPath({"ReplicatedStorage", "RemoteServices", "HealingService", "RF", "UseHeal"})
local useWeaponRemote = secureFetchPath({"ReplicatedStorage", "RemoteServices", "CombatService", "RF", "UseWeapon"})
local startDungeonRemote = secureFetchPath({"ReplicatedStorage", "RemoteServices", "DungeonService", "RF", "StartDungeon"})

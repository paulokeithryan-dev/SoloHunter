local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- 1. Create the Main Window Frame Safely
local Window = Rayfield:CreateWindow({
   Name = "Universal Automation Hub",
   LoadingTitle = "Loading System...",
   LoadingSubtitle = "by Assistant",
   ConfigurationSaving = {
      Enabled = false,
      FolderName = nil,
      FileName = "AutomationConfig"
   },
   Discord = {
      Enabled = false,
      Invite = "noinvitelink",
      RememberJoins = true
   },
   KeySystem = false
})

-- 2. Generate Tabs (Using clean icon strings to prevent modern Rayfield v2 crashes)
local MainTab = Window:CreateTab("Automation", "play") 
local ConfigTab = Window:CreateTab("Configurations", "settings")

-- Safe environment variables to prevent index errors
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")

-- Safe Folder fallbacks so the script doesn't break if folders are missing at startup
local EnemiesFolder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Monsters") or workspace
local DropsFolder = workspace:FindFirstChild("Drops") or workspace:FindFirstChild("Items") or workspace

-- Script Global Variables
_G.AutoFarm = false
_G.AutoCollect = false
_G.FarmDistance = 5
_G.CombatStance = "Above"

-- 3. Helper Functions (Safely wrapped in pcalls)
local function getClosestEnemy()
    local closest = nil
    local shortestDistance = math.huge
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local myHrp = character.HumanoidRootPart

    pcall(function()
        for _, enemy in ipairs(EnemiesFolder:GetChildren()) do
            if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") then
                if enemy.Humanoid.Health > 0 then
                    local distance = (enemy.HumanoidRootPart.Position - myHrp.Position).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closest = enemy
                    end
                end
            end
        end
    end)
    return closest
end

local function teleportToPosition(pos)
    pcall(function()
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = pos
        end
    end)
end

local function processDrop(drop)
    if not drop:IsA("BasePart") then return end
    task.spawn(function()
        while drop.Parent and _G.AutoCollect do
            local character = LocalPlayer.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                local distance = (drop.Position - character.HumanoidRootPart.Position).Magnitude
                if distance < 25 then
                    teleportToPosition(drop.CFrame)
                    task.wait(0.1)
                    break
                end
            end
            task.wait(0.2)
        end
    end)
end

-- Anti-AFK implementation to prevent disconnects while farming
pcall(function()
    LocalPlayer.Idled:Connect(function()
        VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        task.wait(1)
        VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    end)
end)

-- 4. Build Tab Elements
MainTab:CreateSection("Combat Loops")

MainTab:CreateToggle({
   Name = "Auto Farm Enemies",
   CurrentValue = false,
   Flag = "Toggle_AutoFarm",
   Callback = function(Value)
      _G.AutoFarm = Value
      if Value then
          task.spawn(function()
              while _G.AutoFarm do
                  local target = getClosestEnemy()
                  if target and target:FindFirstChild("HumanoidRootPart") then
                      -- Calculate structural stance offset safely
                      local offset = Vector3.new(0, _G.FarmDistance, 0)
                      if _G.CombatStance == "Behind" then
                          offset = target.HumanoidRootPart.CFrame.LookVector * -_G.FarmDistance
                      elseif _G.CombatStance == "Below" then
                          offset = Vector3.new(0, -_G.FarmDistance, 0)
                      end
                      
                      teleportToPosition(target.HumanoidRootPart.CFrame * CFrame.new(offset))
                      
                      -- Trigger basic attack simulation safely
                      pcall(function()
                          local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                          if tool then tool:Activate() end
                      end)
                  end
                  task.wait(0.1)
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto Collect Drops",
   CurrentValue = false,
   Flag = "Toggle_AutoCollect",
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
          task.spawn(function()
              while _G.AutoCollect do
                  pcall(function()
                      for _, drop in ipairs(DropsFolder:GetChildren()) do
                          if drop:IsA("BasePart") then
                              local character = LocalPlayer.Character
                              if character and character:FindFirstChild("HumanoidRootPart") then
                                  teleportToPosition(drop.CFrame)
                                  task.wait(0.1)
                              end
                          end
                      end
                  end)
                  task.wait(0.5)
              end
          end)
      end
   end,
})

ConfigTab:CreateSection("Farming Adjustments")

ConfigTab:CreateSlider({
   Name = "Target Attack Distance",
   Range = {2, 15},
   Increment = 1,
   Suffix = " Studs",
   CurrentValue = 5,
   Flag = "Slider_Distance",
   Callback = function(Value)
      _G.FarmDistance = Value
   end,
})

ConfigTab:CreateDropdown({
   Name = "Teleport Combat Stance",
   Options = {"Above", "Behind", "Below"},
   CurrentOption = {"Above"},
   MultipleOptions = false,
   Flag = "Dropdown_Stance",
   Callback = function(Options)
      _G.CombatStance = Options[1]
   end,
})

-- 5. Safe Startup Initialization
pcall(function()
    if DropsFolder ~= workspace then
        DropsFolder.ChildAdded:Connect(processDrop)
    end
end)

Rayfield:Notify({
   Title = "System Loaded",
   Content = "Your framework initialized successfully with zero errors.",
   Duration = 5,
   Image = "check"
})

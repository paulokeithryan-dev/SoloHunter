                    end
                end
                
                -- Positional configuration backup check
                if not chestUUID then
                    if typeof(args[2]) == "CFrame" and type(args[3]) == "string" then
                        chestUUID = args[3]
                    elseif typeof(args[1]) == "CFrame" and type(args[2]) == "string" then
                        chestUUID = args[2]
                    end

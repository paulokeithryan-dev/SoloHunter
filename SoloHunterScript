-- // CORE HELPERS & STATE EVALUATION // --

local BLACKLIST_KEYWORDS = {"dummy", "npc", "citizen", "merchant", "shop", "quest", "bank", "innocent", "friendly", "guide", "helper", "trainer"}

local function isEnemyValid(model)
    if not model or not model.Parent or model == player.Character then return false end
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    local root = model:FindFirstChild("HumanoidRootPart")
    
    if humanoid and root and humanoid.Health > 0 and humanoid.MaxHealth > 0 then
        local nameLower = model.Name:lower()
        for i = 1, #BLACKLIST_KEYWORDS do
            if string.find(nameLower, BLACKLIST_KEYWORDS[i]) then return false end
        end
        return true
    end
    return false
end

-- Update Engine State (Runs periodically to determine what the local player should be doing)
local function evaluateState()
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if not humanoid or humanoid.Health <= 0 then
        EngineState = "Idle"
        return
    end

    -- Priority 1: Safe Spot
    if safeSpotEnabled then
        local hpPercent = (humanoid.Health / humanoid.MaxHealth) * 100
        if hpPercent <= safeHpPercent then
            if EngineState ~= "SafeSpot" then
                EngineState = "SafeSpot"
                updateNoclipState()
            end
            return
        elseif hpPercent >= 90 and EngineState == "SafeSpot" then
            EngineState = "Idle"
            updateNoclipState()
        end
    end

    -- Priority 2: Combat/Movement
    if EngineState == "SafeSpot" then return end 
    
    if (autoAttackEnabled or autoSkillsEnabled) and targetEnemy then
        EngineState = "Combat"
    else
        EngineState = "Idle"
    end
end


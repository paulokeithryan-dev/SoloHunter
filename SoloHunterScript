-- // WORKSPACE PROXIMITY PORTAL INTERACTION MODULE // --
local function triggerPortalInteraction(portalModel)
    local prompt = portalModel:FindFirstChildOfClass("ProximityPrompt") or portalModel:FindFirstChild("ProximityPrompt", true)
    
    if prompt then
        pcall(function()
            prompt.RequiresLineOfSight = false
            prompt.MaxActivationDistance = 500
            prompt.Enabled = true
        end)
        
        if fireproximityprompt then
            pcall(function() fireproximityprompt(prompt) end)
        else
            pcall(function()
                prompt:InputHoldBegin()
                task.wait(prompt.HoldDuration + 0.1)
                prompt:InputHoldEnd()
            end)
        end
    end
end

local function handleDemonCastlePortal(portalModel)
    if not autoDemonCastleEnabled then return end
    task.wait(0.5) 
    
    local destinationPart = portalModel:FindFirstChild("ProximityPart") 
        or portalModel:FindFirstChild("Gate") 
        or portalModel:FindFirstChildOfClass("BasePart")
    
    if destinationPart then
        local character = player.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        
        if root then
            -- Pause Auto-Attack during progression sequence so combat flight physics don't overwrite the tween
            local wasAutoAttackEnabled = autoAttackEnabled
            autoAttackEnabled = false
            
            -- Calculate a safe 6-stud boundary point relative to player's current incoming position
            local offsetDirection = (root.Position - destinationPart.Position)
            local finalDirection = offsetDirection.Magnitude > 0 and offsetDirection.Unit or Vector3.new(0, 0, 1)
            local targetPosition = destinationPart.Position + (finalDirection * 6)
            
            -- Look orientation towards the portal gate
            local lookCFrame = CFrame.lookAt(targetPosition, destinationPart.Position)
            
            -- Calculate dynamic tween speed depending on how far player is from the portal
            local distance = (root.Position - targetPosition).Magnitude
            local calculatedTime = math.clamp(distance / tweenSpeed, 0.5, 3.5)
            
            local tweenInfo = TweenInfo.new(calculatedTime, Enum.EasingStyle.Linear)
            local tween = TweenService:Create(root, tweenInfo, {CFrame = lookCFrame})
            
            tween:Play()
            tween.Completed:Wait() -- Ensure the player stops exactly at the 6-stud mark
            
            -- Execute the Remote Invocation (Your specific event listener)
            pcall(function()
                queuePortalRemote:InvokeServer("ac8172bb-b04b-453a-9500-513449a0f30c")
            end)
            
            -- Wait a frame, then trigger fallback prompt interaction as backup
            task.wait(0.35)
            triggerPortalInteraction(portalModel)
            
            -- Re-enable Auto Attack state
            task.wait(0.5)
            autoAttackEnabled = wasAutoAttackEnabled
        end
    end
end


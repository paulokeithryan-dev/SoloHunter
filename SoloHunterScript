-- // CORE TARGETING ENGINE // --
local targetEnemy = nil

local function isEnemy(model)
    if model:IsA("Model") and model ~= player.Character then
        local humanoid = model:FindFirstChildOfClass("Humanoid")
        local root = model:FindFirstChild("HumanoidRootPart")
        if humanoid and root and humanoid.Health > 0 then
            return true
        end
    end
    return false
end

local function getClosestEnemy()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local playerRoot = character.HumanoidRootPart
    local closestEnemy = nil
    local shortestDistance = autoAttackRange 

    for _, obj in pairs(workspace:GetDescendants()) do
        if isEnemy(obj) then
            local distance = (playerRoot.Position - obj.HumanoidRootPart.Position).Magnitude
            if distance <= shortestDistance then
                shortestDistance = distance
                closestEnemy = obj
            end
        end
    end
    return closestEnemy
end

task.spawn(function()
    while true do
        if autoAttackEnabled or autoSkillsEnabled then
            targetEnemy = getClosestEnemy()
        else
            targetEnemy = nil
        end
        task.wait(0.1)
    end
end)


-- // SYSTEM MODULES // --

-- 1. ADVANCED MOVEMENT & ALIGNMENT MODULE (Dynamic Overheads)
RunService.Heartbeat:Connect(function(deltaTime)
    if not autoAttackEnabled then return end

    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not root or (humanoid and humanoid.Health <= 0) then return end
    
    if targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") and targetEnemy:FindFirstChildOfClass("Humanoid") and targetEnemy:FindFirstChildOfClass("Humanoid").Health > 0 then
        local enemyRoot = targetEnemy.HumanoidRootPart
        local targetPosition
        
        -- Dynamic Safe Spot Vector Adjustments
        if safeSpotActive then
            -- Bypasses general orbit math to float strictly directly over enemy coordinates safely
            targetPosition = enemyRoot.Position + Vector3.new(0.01, SAFE_HOVER_HEIGHT, 0)
        else
            -- Normal Combat Flight Operations
            if positioningMode == "Above" then
                targetPosition = enemyRoot.Position + Vector3.new(0.01, HOVER_HEIGHT, 0)
            elseif positioningMode == "Circle" then
                circleAngle = circleAngle + (deltaTime * 2.5) 
                local radius = attackDistance
                local offsetX = math.cos(circleAngle) * radius
                local offsetZ = math.sin(circleAngle) * radius
                targetPosition = enemyRoot.Position + Vector3.new(offsetX, HOVER_HEIGHT, offsetZ)
            end
        end
        
        -- Translation Router (Forces smooth linear glide when Safe Spotting to prevent anti-cheat triggers)
        if movementMethod == "Teleport" and not safeSpotActive then
            root.CFrame = CFrame.lookAt(targetPosition, enemyRoot.Position)
        else
            local currentPos = root.Position
            local travelVector = (targetPosition - currentPos)
            local dist = travelVector.Magnitude
            
            if dist <= 1.5 then
                root.CFrame = CFrame.lookAt(targetPosition, enemyRoot.Position)
            else
                local operationalSpeed = safeSpotActive and 200 or tweenSpeed
                local glideStep = math.min(dist, operationalSpeed * deltaTime)
                local calculatedPosition = currentPos + (travelVector.Unit * glideStep)
                root.CFrame = CFrame.lookAt(calculatedPosition, enemyRoot.Position)
            end
        end
        
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    else
        targetEnemy = nil
    end
end)


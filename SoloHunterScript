-- // UNLOCKED TARGET SCANNER // --
local function isEnemy(model)
    if model and model:IsA("Model") and model ~= player.Character then
        local humanoid = model:FindFirstChildOfClass("Humanoid")
        local root = model:FindFirstChild("HumanoidRootPart")
        if humanoid and root and humanoid.Health > 0 then return true end
    end
    return false
end

local function getClosestEnemy()
    local character = player.Character
    local playerRoot = character and character:FindFirstChild("HumanoidRootPart")
    if not playerRoot then return nil end
    
    local closestEnemy = nil
    local shortestDistance = MAX_DETECTION_DIST

    for _, obj in ipairs(workspace:GetDescendants()) do
        if isEnemy(obj) then
            local distance = (playerRoot.Position - obj.HumanoidRootPart.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestEnemy = obj
            end
        end
    end
    return closestEnemy
end

local targetEnemy = nil
task.spawn(function()
    while true do
        if systemEnabled then
            targetEnemy = getClosestEnemy()
        else
            targetEnemy = nil
        end
        task.wait(0.05) 
    end
end)

-- // HIGH-RECALCULATION PATHFINDING LOCOMOTION ENGINE // --
task.spawn(function()
    while true do
        task.wait(0.1) -- Rapid repathing to track moving enemies accurately
        if systemEnabled and targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") then
            local character = player.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local root = character and character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and root and humanoid.Health > 0 then
                local enemyRoot = targetEnemy.HumanoidRootPart
                local distanceToEnemy = (root.Position - enemyRoot.Position).Magnitude
                
                -- Only walk if we are further out than the stop distance configuration
                if distanceToEnemy > STOP_DISTANCE then
                    local success, _ = pcall(function()
                        path:ComputeAsync(root.Position, enemyRoot.Position)
                    end)
                    
                    if success and path.Status == Enum.PathStatus.Success then
                        local waypoints = path:GetWaypoints()
                        if #waypoints > 1 then
                            local nextWaypoint = waypoints[2] -- Index 1 is current pos, 2 is next step
                            
                            -- Handle jumping over obstacles automatically
                            if nextWaypoint.Action == Enum.PathWaypointAction.Jump then
                                humanoid.Jump = true
                            end
                            
                            humanoid:MoveTo(nextWaypoint.Position)
                        else
                            humanoid:MoveTo(enemyRoot.Position)
                        end
                    else
                        -- Physics Fallback
                        humanoid:MoveTo(enemyRoot.Position)
                    end
                else
                    -- Stop moving and face the target directly when close enough to attack
                    humanoid:MoveTo(root.Position)
                    root.CFrame = CFrame.lookAt(root.Position, Vector3.new(enemyRoot.Position.X, root.Position.Y, enemyRoot.Position.Z))
                end
            end
        end
    end
end)


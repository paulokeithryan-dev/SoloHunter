local function createBtn(text, pos, color, callback)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

local toggleBtn = createBtn("SYSTEM: OFF", UDim2.new(0, 5, 0, 5), Color3.fromRGB(200, 60, 60), function()
    systemEnabled = not systemEnabled
    toggleBtn.Text = systemEnabled and "SYSTEM: ON" or "SYSTEM: OFF"
    toggleBtn.BackgroundColor3 = systemEnabled and Color3.fromRGB(60, 200, 60) or Color3.fromRGB(200, 60, 60)
end)

createBtn("Auto-Equip", UDim2.new(0, 5, 0, 45), Color3.fromRGB(60, 150, 200), function() autoEquipEnabled = not autoEquipEnabled end)
createBtn("Auto-Collect", UDim2.new(0, 5, 0, 85), Color3.fromRGB(140, 60, 200), function() autoCollectEnabled = not autoCollectEnabled end)
createBtn("Auto-Potion", UDim2.new(0, 5, 0, 125), Color3.fromRGB(210, 130, 40), function() autoPotionEnabled = not autoPotionEnabled end)
createBtn("Auto-Dungeon", UDim2.new(0, 5, 0, 165), Color3.fromRGB(220, 60, 100), function() autoDungeonEnabled = not autoDungeonEnabled end)

-- // COMBAT & TARGETING // --
local function getClosestEnemy()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local closest, shortest = nil, MAX_DETECTION_DIST
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= character and obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 and obj:FindFirstChild("HumanoidRootPart") then
            local dist = (character.HumanoidRootPart.Position - obj.HumanoidRootPart.Position).Magnitude
            if dist < shortest then closest, shortest = obj, dist end
        end
    end
    return closest
end

-- // POSITIONING & AIMING // --
RunService.Heartbeat:Connect(function()
    if not systemEnabled then return end
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    targetEnemy = getClosestEnemy()
    
    if targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart") and root then
        local enemyRoot = targetEnemy.HumanoidRootPart
        local _, boxSize = targetEnemy:GetBoundingBox()
        local targetY = enemyRoot.Position.Y + (boxSize.Y / 2) + HOVER_HEIGHT
        root.CFrame = CFrame.lookAt(Vector3.new(enemyRoot.Position.X, targetY, enemyRoot.Position.Z), enemyRoot.Position)
        root.AssemblyLinearVelocity = Vector3.zero
    end
end)

-- // AUTO-POTION LOOP // --
task.spawn(function()
    while task.wait(0.3) do
        if systemEnabled and autoPotionEnabled then
            local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health / humanoid.MaxHealth <= 0.5 then
                pcall(function() healRemote:InvokeServer() end)
                task.wait(1.5)
            end
        end
    end
end)

-- // DROP COLLECTION // --
local function processDrop(obj)
    if not systemEnabled or not autoCollectEnabled then return end
    local name = obj.Name:lower()
    if name:find("drop") or name:find("loot") or name:find("item") or obj:IsA("ProximityPrompt") then
        pcall(function() dropRemote:InvokeServer(obj) end)
    end
end

workspace.DescendantAdded:Connect(processDrop)

-- // AUTO WEAPON EQUIP // --
task.spawn(function()
    while task.wait(0.5) do
        if systemEnabled and autoEquipEnabled then
            local character = player.Character
            if character and character:FindFirstChildOfClass("Humanoid").Health > 0 and not character:FindFirstChildOfClass("Tool") then
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
            end
        end
    end
end)

-- // HYBRID ATTACK LOOP // --
task.spawn(function()
    while task.wait(M1_SPEED) do
        if systemEnabled and targetEnemy then
            pcall(function() useWeaponRemote:InvokeServer(1, {targetEnemy}, 0.4, "", "CS_HW_V1") end)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
    end
end)

-- // AUTO-DUNGEON // --
task.spawn(function()
    while task.wait(1.5) do
        if systemEnabled and autoDungeonEnabled then
            pcall(function() startDungeonRemote:InvokeServer() end)
            pcall(function() enterGateRemote:InvokeServer() end)
        end
    end
end)

-- // AUTO SKILL CAST // --
task.spawn(function()
    local skills = {Enum.KeyCode.F, Enum.KeyCode.R, Enum.KeyCode.C}
    while task.wait(SKILL_INTERVAL) do
        if systemEnabled and targetEnemy then
            for _, key in ipairs(skills) do
                VirtualInputManager:SendKeyEvent(true, key, false, game)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, key, false, game)
            end
        end
    end
end)

-- 1. ADVANCED MOVEMENT & ALIGNMENT MODULE (Separated concerns)
local function getDesiredPosition(enemyRoot, deltaTime)
    if EngineState == "SafeSpot" then
        return enemyRoot.Position + Vector3.new(0.01, SAFE_HOVER_HEIGHT, 0)
    end
    
    if positioningMode == "Above" then
        return enemyRoot.Position + Vector3.new(0.01, HOVER_HEIGHT, 0)
    elseif positioningMode == "Circle" then
        circleAngle = circleAngle + (deltaTime * 2.5) 
        local radius = attackDistance
        local offsetX = math.cos(circleAngle) * radius
        local offsetZ = math.sin(circleAngle) * radius
        return enemyRoot.Position + Vector3.new(offsetX, HOVER_HEIGHT, offsetZ)
    end
    return enemyRoot.Position
end

RunService.Heartbeat:Connect(function(deltaTime)
    if not autoAttackEnabled and EngineState ~= "SafeSpot" then return end
    if not targetEnemy then return end
    
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local enemyRoot = targetEnemy:FindFirstChild("HumanoidRootPart")
    
    if not root or not enemyRoot then return end
    
    local targetPosition = getDesiredPosition(enemyRoot, deltaTime)
    local currentPos = root.Position
    local travelVector = targetPosition - currentPos
    local dist = travelVector.Magnitude

    -- Tolerance check: Avoid CFrame writes if we are already there
    if dist > 0.5 or exactPartAlignment then
        local newCFrame
        if movementMethod == "Teleport" and EngineState ~= "SafeSpot" then
            newCFrame = CFrame.lookAt(targetPosition, enemyRoot.Position)
        else
            local operationalSpeed = (EngineState == "SafeSpot") and 200 or tweenSpeed
            local glideStep = math.min(dist, operationalSpeed * deltaTime)
            local calculatedPosition = currentPos + (travelVector.Unit * glideStep)
            newCFrame = CFrame.lookAt(calculatedPosition, enemyRoot.Position)
        end
        root.CFrame = newCFrame
    elseif not exactPartAlignment then
        -- Only aim if we are already close enough
        root.CFrame = CFrame.lookAt(currentPos, enemyRoot.Position)
    end
    
    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end)


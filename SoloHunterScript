-- // EXTENDED DROP VACUUM SYSTEM // --
local function processDrop(obj)
    if not systemEnabled or not autoCollectEnabled or not obj then return end
    
    if obj:IsA("ProximityPrompt") then
        task.spawn(function()
            if fireproximityprompt then
                fireproximityprompt(obj)
            else
                pcall(function() dropRemote:InvokeServer(obj) end)
                if obj.Parent and obj.Parent:IsA("Model") then
                    pcall(function() dropRemote:InvokeServer(obj.Parent) end)
                end
            end
        end)
        return
    end

    local nameLower = obj.Name:lower()
    local parentNameLower = (obj.Parent and obj.Parent.Name:lower()) or ""
    
    local isDrop = nameLower:find("drop") 
        or nameLower:find("loot") 
        or nameLower:find("item")
        or nameLower:find("potion")
        or parentNameLower:find("drop") 
        or parentNameLower:find("loot")
        or obj:IsA("TouchTransmitter")
        
    if isDrop then
        task.spawn(function()
            pcall(function() dropRemote:InvokeServer(obj) end)
            if obj.Parent and obj.Parent:IsA("Model") then
                pcall(function() dropRemote:InvokeServer(obj.Parent) end)
            end
        end)
    end
end

workspace.DescendantAdded:Connect(processDrop)

local cameraInstance = workspace:FindFirstChildOfClass("Camera") or workspace:FindFirstChild("Camera")
if cameraInstance then
    cameraInstance.DescendantAdded:Connect(processDrop)
end

task.spawn(function()
    while true do
        task.wait(0.5)
        if systemEnabled and autoCollectEnabled then
            for _, obj in ipairs(workspace:GetDescendants()) do
                processDrop(obj)
            end
            local activeCam = workspace.CurrentCamera or workspace:FindFirstChild("Camera")
            if activeCam and activeCam:FindFirstChild("Drops") then
                for _, obj in ipairs(activeCam.Drops:GetDescendants()) do
                    processDrop(obj)
                end
            end
        end
    end
end)


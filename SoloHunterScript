local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- // SAFE REMOTE RESOLUTION (Prevents crashes if paths are slightly different) // --
local function getRemote(...)
    local path = {...}
    local obj = ReplicatedStorage
    for _, name in ipairs(path) do
        obj = obj and obj:FindFirstChild(name)
    end
    return obj
end

local dropRemote = getRemote("RemoteServices", "DropsService", "RF", "CollectDrop")
local healRemote = getRemote("RemoteServices", "HealingService", "RF", "UseHeal")
local useWeaponRemote = getRemote("RemoteServices", "CombatService", "RF", "UseWeapon")
local startDungeonRemote = getRemote("RemoteServices", "DungeonService", "RF", "StartDungeon")
local enterGateRemote = getRemote("RemoteServices", "PortalService", "RF", "CanEnterGate")

-- // STATE FLAGS & CONFIG // --
local systemEnabled = false
local autoEquipEnabled = true 
local autoCollectEnabled = true  
local autoPotionEnabled = true   
local autoDungeonEnabled = true 

local HOVER_HEIGHT = 4        
local MAX_DETECTION_DIST = 300  
local M1_SPEED = 0.1            
local SKILL_INTERVAL = 1.5      
local targetEnemy = nil


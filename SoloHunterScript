-- // FIXED PORTAL SCANNING ENGINE // --
local function refreshPortalList()
    for _, child in ipairs(portalScroll:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local itemsCount = 0
    
    -- Scans entire workspace recursively for any generic "PortalModel"
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "PortalModel" then
            itemsCount = itemsCount + 1
            
            local displayTitle = "Portal Model [Unparsed]"
            local rawStrings = {}
            
            -- Scrape active text labels found inside its SurfaceGuis/BillboardGuis
            for _, descendant in ipairs(obj:GetDescendants()) do
                if descendant:IsA("TextLabel") and descendant.Text ~= "" and #descendant.Text < 40 then
                    table.insert(rawStrings, descendant.Text)
                end
            end
            
            -- Reconstruct label based on UI values extracted (e.g., "The Subway - Level 30")
            if #rawStrings > 0 then
                local mainZone = rawStrings[1] or "Unknown"
                local zoneMeta = rawStrings[2] or "Unknown Level"
                displayTitle = string.format("%s (%s)", mainZone, zoneMeta)
            end
            
            local pBtn = Instance.new("TextButton")
            pBtn.Size = UDim2.new(1, -8, 0, 32)
            pBtn.BackgroundColor3 = Color3.fromRGB(85, 45, 115) -- Distinct color for parsed gates
            pBtn.Text = displayTitle
            pBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            pBtn.Font = Enum.Font.SourceSansBold
            pBtn.TextSize = 12
            pBtn.Parent = portalScroll
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 5)
            btnCorner.Parent = pBtn
            
            -- Dynamic click verification sequence
            pBtn.MouseButton1Click:Connect(function()
                local character = player.Character
                local root = character and character:FindFirstChild("HumanoidRootPart")
                local proximityPart = obj:FindFirstChild("ProximityPart")
                
                if root and proximityPart then
                    -- Relocate directly into prompt calculation frame
                    root.CFrame = proximityPart.CFrame
                    task.wait(0.2)
                    
                    -- Trigger interaction prompt directly via your environment capabilities
                    local prompt = proximityPart:FindFirstChildOfClass("ProximityPrompt")
                    if prompt and fireproximityprompt then
                        fireproximityprompt(prompt)
                    end
                end
            end)
        end
    end
    
    portalScroll.CanvasSize = UDim2.new(0, 0, 0, itemsCount * 36)
end


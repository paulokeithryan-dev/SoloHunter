-- Safe environment variables
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Strict Folder Mapping
local Camera = workspace:FindFirstChild("Camera")
local DropsFolder = (Camera and Camera:FindFirstChild("Drops")) or workspace:FindFirstChild("Drops")
local EnemiesFolder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Monsters")

-- Global Script Configuration
local Options = Fluent.Options
_G.AutoFarm = false
_G.AutoCollect = false
_G.FarmDistance = 5
_G.CombatStance = "Above"

-- Dynamic Safe Remote Resolvers (Fixes the global scope crash)
local function getCollectDropRemote()
    local rs = ReplicatedStorage:FindFirstChild("RemoteServices")
    local ds = rs and rs:FindFirstChild("DropsService")
    local rfFolder = ds and ds:FindFirstChild("RF")
    return rfFolder and rfFolder:FindFirstChild("CollectDrop")
end

local function getUseWeaponRemote()
    local rs = ReplicatedStorage:FindFirstChild("RemoteServices")
    local cs = rs and rs:FindFirstChild("CombatService")
    local rfFolder = cs and cs:FindFirstChild("RF")
    return rfFolder and rfFolder:FindFirstChild("UseWeapon")
end

-- Targeting Math Helper
local function getClosestEnemy()
    if not EnemiesFolder then return nil end
    local closest = nil
    local shortestDistance = math.huge
    
    local character = LocalPlayer.Character
    local myHrp = character and character:FindFirstChild("HumanoidRootPart")
    if not myHrp then return nil end

    pcall(function()
        for _, enemy in ipairs(EnemiesFolder:GetChildren()) do
            if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") then
                if enemy.Humanoid.Health > 0 then
                    local distance = (enemy.HumanoidRootPart.Position - myHrp.Position).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closest = enemy
                    end
                end
            end
        end
    end)
    return closest
end

local function teleportToPosition(pos)
    pcall(function()
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = pos
        end
    end)
end

-- Anti-AFK Handler
pcall(function()
    LocalPlayer.Idled:Connect(function()
        VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        task.wait(1)
        VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    end)
end)

-- Automation Tab Configuration
Tabs.Main:AddSection("Combat Loops")

local ToggleFarm = Tabs.Main:AddToggle("Toggle_AutoFarm", {Title = "Auto Farm Enemies", Default = false })
ToggleFarm:OnChanged(function()
    _G.AutoFarm = Options.Toggle_AutoFarm.Value
    if _G.AutoFarm then
        task.spawn(function()
            while _G.AutoFarm do
                local target = getClosestEnemy()
                if target and target:FindFirstChild("HumanoidRootPart") then
                    
                    local targetCFrame = target.HumanoidRootPart.CFrame
                    local finalCFrame = targetCFrame * CFrame.new(0, _G.FarmDistance, 0)
                    
                    if _G.CombatStance == "Behind" then
                        finalCFrame = targetCFrame * CFrame.new(0, 0, _G.FarmDistance)
                    elseif _G.CombatStance == "Below" then
                        finalCFrame = targetCFrame * CFrame.new(0, -_G.FarmDistance, 0)
                    end
                    
                    teleportToPosition(finalCFrame)
                    
                    pcall(function()
                        local weaponRF = getUseWeaponRemote()
                        if weaponRF then
                            -- Packed safely without mid-tuple raw nils to prevent payload dropping
                            weaponRF:InvokeServer(1, { target }, 0.4, "", "CS_HW_V1")[cite: 3]
                        else
                            local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if tool then tool:Activate() end
                        end
                    end)
                end
                task.wait(0.1)
            end
        end)
    end
end)

local ToggleCollect = Tabs.Main:AddToggle("Toggle_AutoCollect", {Title = "Auto Collect Drops", Default = false })
ToggleCollect:OnChanged(function()
    _G.AutoCollect = Options.Toggle_AutoCollect.Value
    if _G.AutoCollect then
        task.spawn(function()
            while _G.AutoCollect do
                pcall(function()
                    if DropsFolder then
                        local collectRF = getCollectDropRemote()
                        for _, drop in ipairs(DropsFolder:GetChildren()) do
                            if collectRF then
                                task.spawn(function()
                                    collectRF:InvokeServer(drop)
                                end)
                            else
                                teleportToPosition(drop.CFrame)
                                task.wait(0.1)
                            end
                        end
                    end
                 pcall(function()
                end)
               end)
               task.wait(0.4)
            end
        end)
    end
end)


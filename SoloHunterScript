-- Auto Collect Module
task.spawn(function()
    while true do
        task.wait(0.2)
        if systemEnabled and autoCollectEnabled and dropRemote then
            local activeCam = workspace.CurrentCamera
            local dropsFolder = activeCam and activeCam:FindFirstChild("Drops")
            if dropsFolder then
                for _, item in ipairs(dropsFolder:GetDescendants()) do
                    if item:IsA("BasePart") or item:IsA("Model") then
                        local id = string.match(item.Name, "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x")
                        if id and not processedDrops[id] then
                            processedDrops[id] = true
                            pcall(function() dropRemote:InvokeServer(id) end)
                        end
                    end
                end
            end
        end
    end
end)


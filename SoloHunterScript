-- 1. Create the Main Window Frame Safely
local Window = Rayfield:CreateWindow({
   Name = "Universal Automation Hub",
   LoadingTitle = "Loading System...",
   LoadingSubtitle = "by Assistant",
   ConfigurationSaving = {
      Enabled = false,
      FolderName = "AutomationHub"
   },
   Discord = {
      Enabled = false,
      Invite = "",
      RememberJoins = false
   },
   KeySystem = false
})

-- 2. Generate Tabs
local MainTab = Window:CreateTab("Automation", "play") 
local ConfigTab = Window:CreateTab("Configurations", "settings")

-- Safe environment variables
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Exact Network Services & Remotes Structure
local RemoteServices = ReplicatedStorage:WaitForChild("RemoteServices", 5)

local CollectDropRF = RemoteServices 
    and RemoteServices:WaitForChild("DropsService", 5) 
    and RemoteServices.DropsService:WaitForChild("RF", 5) 
    and RemoteServices.DropsService.RF:WaitForChild("CollectDrop", 5)

local UseWeaponRF = RemoteServices 
    and RemoteServices:WaitForChild("CombatService", 5)
    and RemoteServices.CombatService:WaitForChild("RF", 5)
    and RemoteServices.CombatService.RF:WaitForChild("UseWeapon", 5)

-- Strict Folder Mapping (Prevents workspace flooding)
local Camera = workspace:FindFirstChild("Camera")
local DropsFolder = (Camera and Camera:FindFirstChild("Drops")) or workspace:FindFirstChild("Drops")
local EnemiesFolder = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Monsters")

-- Script Global Variables
_G.AutoFarm = false
_G.AutoCollect = false
_G.FarmDistance = 5
_G.CombatStance = "Above"

-- 3. Helper Functions
local function getClosestEnemy()
    if not EnemiesFolder then return nil end
    local closest = nil
    local shortestDistance = math.huge
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local myHrp = character.HumanoidRootPart

    pcall(function()
        for _, enemy in ipairs(EnemiesFolder:GetChildren()) do
            if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") then
                if enemy.Humanoid.Health > 0 then
                    local distance = (enemy.HumanoidRootPart.Position - myHrp.Position).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closest = enemy
                    end
                end
            end
        end
    end)
    return closest
end

local function teleportToPosition(pos)
    pcall(function()
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = pos
        end
    end)
end

local function processDrop(drop)
    if not _G.AutoCollect or not CollectDropRF then return end
    task.spawn(function()
        pcall(function()
            CollectDropRF:InvokeServer(drop)
        end)
    end)
end

-- Anti-AFK
pcall(function()
    LocalPlayer.Idled:Connect(function()
        VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        task.wait(1)
        VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    end)
end)

-- 4. Build Tab Elements
MainTab:CreateSection("Combat Loops")

MainTab:CreateToggle({
   Name = "Auto Farm Enemies",
   CurrentValue = false,
   Flag = "Toggle_AutoFarm",
   Callback = function(Value)
      _G.AutoFarm = Value
      if Value then
          task.spawn(function()
              while _G.AutoFarm do
                  local target = getClosestEnemy()
                  if target and target:FindFirstChild("HumanoidRootPart") then
                      
                      -- Corrected Pure Local CFrame Transformations
                      local targetCFrame = target.HumanoidRootPart.CFrame
                      local finalCFrame = targetCFrame * CFrame.new(0, _G.FarmDistance, 0) -- Default Above
                      
                      if _G.CombatStance == "Behind" then
                          finalCFrame = targetCFrame * CFrame.new(0, 0, _G.FarmDistance)
                      elseif _G.CombatStance == "Below" then
                          finalCFrame = targetCFrame * CFrame.new(0, -_G.FarmDistance, 0)
                      end
                      
                      teleportToPosition(finalCFrame)
                      
                      -- Remote Weapon Invocation
                      pcall(function()
                          if UseWeaponRF then
                              UseWeaponRF:InvokeServer(1, { target }, 0.4, nil, "CS_HW_V1")
                          else
                              local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                              if tool then tool:Activate() end
                          end
                      end)
                  end
                  task.wait(0.1)
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto Collect Drops",
   CurrentValue = false,
   Flag = "Toggle_AutoCollect",
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
          task.spawn(function()
              while _G.AutoCollect do
                  pcall(function()
                      if DropsFolder then
                          for _, drop in ipairs(DropsFolder:GetChildren()) do
                              if CollectDropRF then
                                  task.spawn(function()
                                      CollectDropRF:InvokeServer(drop)
                                  end)
                              else
                                  teleportToPosition(drop.CFrame)
                                  task.wait(0.1)
                              end
                          end
                      else
                          warn("[Warning] Drops folder cannot be found in workspace currently.")
                      end
                  end)
                  task.wait(0.4)
              end
          end)
      end
   end,
})

ConfigTab:CreateSection("Farming Adjustments")

ConfigTab:CreateSlider({
   Name = "Target Attack Distance",
   Range = {2, 15},
   Increment = 1,
   Suffix = " Studs",
   CurrentValue = 5,
   Flag = "Slider_Distance",
   Callback = function(Value)
      _G.FarmDistance = Value
   end,
})

ConfigTab:CreateDropdown({
   Name = "Teleport Combat Stance",
   Options = {"Above", "Behind", "Below"},
   CurrentOption = {"Above"},
   MultipleOptions = false,
   Flag = "Dropdown_Stance",
   Callback = function(Options)
      _G.CombatStance = Options[1]
   end,
})

-- 5. Safe Startup Initialization
pcall(function()
    if DropsFolder then
        DropsFolder.ChildAdded:Connect(processDrop)
    end
end)

Rayfield:Notify({
   Title = "System Loaded",
   Content = "Execution engine online with verified stability updates.",
   Duration = 5,
   Image = "check"
})

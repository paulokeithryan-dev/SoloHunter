-- 3. UI Element Builders
local function createToggle(name, callback)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, 40)
    button.BackgroundColor3 = Color3.fromRGB(180, 60, 60) -- Initial Red State
    button.Text = name .. ": OFF"
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.SourceSansBold
    button.TextSize = 16
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = button
    
    local enabled = false
    button.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            button.BackgroundColor3 = Color3.fromRGB(60, 180, 60) -- Green State
            button.Text = name .. ": ON"
        else
            button.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
            button.Text = name .. ": OFF"
        end
        callback(enabled)
    end)
    button.Parent = Container
end

local function createDropdown(name, options, callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(180, 180, 180)
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = Container

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, 35)
    button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    button.Text = options[1]
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.SourceSans
    button.TextSize = 15
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = button

    local currentIndex = 1
    button.MouseButton1Click:Connect(function()
        currentIndex = currentIndex + 1
        if currentIndex > #options then currentIndex = 1 end
        button.Text = options[currentIndex]
        callback(options[currentIndex])
    end)
    button.Parent = Container
end

-- 4. Assembly & Action Loops
createToggle("Auto Farm Enemies", function(val)
    _G.AutoFarm = val
    if val then
        task.spawn(function()
            while _G.AutoFarm do
                local target = getClosestEnemy()
                if target and target:FindFirstChild("HumanoidRootPart") then
                    local offset = Vector3.new(0, _G.FarmDistance, 0)
                    if _G.CombatStance == "Behind" then
                        offset = target.HumanoidRootPart.CFrame.LookVector * -_G.FarmDistance
                    elseif _G.CombatStance == "Below" then
                        offset = Vector3.new(0, -_G.FarmDistance, 0)
                    end
                    
                    teleportToPosition(target.HumanoidRootPart.CFrame * CFrame.new(offset))
                    
                    pcall(function()
                        if UseWeaponRF then
                            UseWeaponRF:InvokeServer(1, { target }, 0.4, nil, "CS_HW_V1")
                        else
                            local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                            if tool then tool:Activate() end
                        end
                    end)
                end
                task.wait(0.1)
            end
        end)
    end
end)

createToggle("Auto Collect Drops", function(val)
    _G.AutoCollect = val
    if val then
        task.spawn(function()
            while _G.AutoCollect do
                pcall(function()
                    if DropsFolder then
                        for _, drop in ipairs(DropsFolder:GetChildren()) do
                            if CollectDropRF then
                                task.spawn(function() CollectDropRF:InvokeServer(drop) end)
                            else
                                teleportToPosition(drop.CFrame)
                                task.wait(0.1)
                            end
                        end
                    end
                end)
                task.wait(0.3)
            end
        end)
    end
end)

createDropdown("Teleport Stance (Click to Cycle)", {"Above", "Behind", "Below"}, function(selection)
    _G.CombatStance = selection
end)

-- Startup background listeners
